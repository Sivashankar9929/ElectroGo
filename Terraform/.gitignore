# Terraform state and provider cache — never commit these
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Real secret files — keep examples, not actuals
terraform.tfvars
backend.hcl
scripts/set-env.sh
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
