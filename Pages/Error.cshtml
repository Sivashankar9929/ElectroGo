@page
@model Microsoft.AspNetCore.Mvc.RazorPages.PageModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="alert alert-danger">
        <h1 class="text-danger">Oops! Something went wrong.</h1>
        <h4 class="text-muted">An error occurred while processing your request.</h4>
    </div>

    <p class="lead">
        Please try again later or contact support if the problem persists.
    </p>

    @* Optional: show request ID for troubleshooting *@
    @if (ViewData["RequestId"] != null)
    {
        <p>
            <strong>Request ID:</strong> <code>@ViewData["RequestId"]</code>
        </p>
    }
</div>
